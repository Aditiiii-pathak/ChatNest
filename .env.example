# ── Database ──────────────────────────────────────────────────────────────────
# For local dev with SQLite (easiest):
USE_SQLITE=1

# For PostgreSQL (recommended in production):
# USE_SQLITE=0
# DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<db>

# On first deploy set this to 1 so SQLAlchemy creates tables automatically.
# Turn it off once your schema is stable / managed by migrations.
DB_AUTO_CREATE_TABLES=1

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Get a key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=8192

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# Generate a strong secret: `python -c "import secrets; print(secrets.token_urlsafe(64))"`
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=1440

# ── Qdrant (vector store) ─────────────────────────────────────────────────────
# Local embedded path (default). For Qdrant Cloud, point this at a URL instead
# and wire up QDRANT_URL / QDRANT_API_KEY in app/core/config.py.
QDRANT_PATH=./qdrant_storage

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins in production.
# Example: https://chatnest.vercel.app,https://chatnest.yourdomain.com
CORS_ALLOW_ORIGINS=

# ── Memory compression ────────────────────────────────────────────────────────
COMPRESSION_BATCH_SIZE=10
